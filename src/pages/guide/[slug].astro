---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { slugify, SITE_URL, SITE_NAME, buildBreadcrumbSchema } from '../../lib/helpers';
import { marked } from 'marked';
import guidesData from '../../data/guides.json';

export function getStaticPaths() {
  return guidesData.guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;

const relatedGuides = guide.relatedGuides
  ? guidesData.guides.filter((g) => guide.relatedGuides.includes(g.slug))
  : [];

const firstSection = guide.sections?.find((s) => s.imageUrl);
const firstImage = firstSection?.imageUrl;
const firstImageAlt = firstSection?.imageAlt || guide.h1;
const firstImageCaption = firstSection?.imageCaption;
const firstImageCredit = firstSection?.imageCredit;
const ogImage = firstImage ? `${SITE_URL}${firstImage}` : undefined;

// Extract clean title without site name suffix for proper SEO
const cleanTitle = guide.seoTitle?.replace(/\s*\|\s*atlanta news.*$/i, '').trim() || guide.h1;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": guide.h1,
  "description": guide.seoDescription,
  "url": `${SITE_URL}/guide/${guide.slug}/`,
  "inLanguage": "en-US",
  ...(firstImage ? { "image": { "@type": "ImageObject", "url": `${SITE_URL}${firstImage}` } } : {}),
  "datePublished": guide.datePublished || "2025-03-01",
  "dateModified": guide.dateModified || guide.datePublished || "2025-03-01",
  "articleSection": guide.category || "Atlanta Guide",
  "author": {
    "@type": "Person",
    "name": "David",
    "url": `${SITE_URL}/about`
  },
  "publisher": {
    "@type": "NewsMediaOrganization",
    "@id": `${SITE_URL}/#organization`,
    "name": SITE_NAME,
    "url": SITE_URL,
    "logo": `${SITE_URL}/favicon.svg`
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${SITE_URL}/guide/${guide.slug}/`
  },
  "spatialCoverage": {
    "@type": "City",
    "name": "Atlanta",
    "@id": "https://www.wikidata.org/wiki/Q23556"
  }
};

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: SITE_URL },
  { name: 'Guides', url: `${SITE_URL}/guide` },
  { name: guide.title, url: `${SITE_URL}/guide/${guide.slug}` },
]);
---

<Base
  title={cleanTitle}
  description={guide.seoDescription}
  ogImage={ogImage}
  jsonLd={jsonLd}
  breadcrumbSchema={breadcrumbSchema}
>
  <article class="guide-page">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Guides', href: '/guide' },
      { label: guide.title },
    ]} />

    <header class="guide-header">
      <h1 class="guide-h1">{guide.h1}</h1>
      <p class="guide-byline">by <a href="/about/">David</a> in <a href="/neighborhoods/summerhill/">Summerhill</a></p>
    </header>

    {firstImage && (
      <figure class="guide-hero">
        <img src={firstImage} alt={firstImageAlt} class="guide-hero-img" />
        {(firstImageCaption || firstImageCredit) && (
          <figcaption class="guide-hero-caption">
            {firstImageCaption && <span class="caption-text">{firstImageCaption}</span>}
            {firstImageCredit && <span class="caption-credit">{firstImageCredit}</span>}
          </figcaption>
        )}
      </figure>
    )}

    <div class="guide-intro prose" set:html={marked.parse(guide.intro)} />

    <div class="guide-body">
      {guide.sections.map((section) => (
        <section class="guide-section">
          <h2>{section.heading}</h2>
          {section.imageUrl && (
            <figure class="guide-section-figure">
              <img src={section.imageUrl} alt={section.imageAlt || section.heading} loading="lazy" />
              {(section.imageCaption || section.imageCredit) && (
                <figcaption>
                  {section.imageCaption && <span class="caption-text">{section.imageCaption}</span>}
                  {section.imageCredit && <span class="caption-credit">{section.imageCredit}</span>}
                </figcaption>
              )}
            </figure>
          )}
          <div class="prose" set:html={marked.parse(section.content)} />
        </section>
      ))}
    </div>

    {relatedGuides.length > 0 && (
      <section class="related-guides">
        <h2 class="related-guides-title">Related Guides</h2>
        <div class="related-guides-grid">
          {relatedGuides.map((g) => (
            <a href={`/guide/${g.slug}/`} class="guide-card">
              <span class="guide-card-title">{g.title}</span>
              <span class="guide-card-desc">{g.seoDescription}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <a href="/guide/" class="back-link">‹ All guides</a>
  </article>
</Base>
