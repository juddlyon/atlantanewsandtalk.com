---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { SITE_URL, buildBreadcrumbSchema } from '../../lib/helpers';
import guidesData from '../../data/guides.json';

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: SITE_URL },
  { name: 'Guides', url: `${SITE_URL}/guide` },
]);

// Get thumbnail for each guide (first section image or fallback)
function getGuideThumbnail(guide: any): string | null {
  if (guide.sections?.[0]?.imageUrl) return guide.sections[0].imageUrl;
  // Check other sections
  for (const section of guide.sections || []) {
    if (section.imageUrl) return section.imageUrl;
  }
  return null;
}

// Featured guides (with images) first, then others
const guidesWithImages = guidesData.guides.filter(g => getGuideThumbnail(g));
const guidesWithoutImages = guidesData.guides.filter(g => !getGuideThumbnail(g));
const sortedGuides = [...guidesWithImages, ...guidesWithoutImages];
---

<Base
  title="Atlanta Guides"
  description="In-depth guides to Atlanta neighborhoods, the BeltLine, restaurants, things to do, and everything else ITP. Written by locals who actually live here."
  breadcrumbSchema={breadcrumbSchema}
>
  <div class="page-container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Guides' },
    ]} />

    <div class="neighborhood-page-header">
      <h1 class="neighborhood-page-title">Atlanta Guides</h1>
      <p class="neighborhood-page-subtitle">
        In-depth guides to ITP life, written by people who actually live here
      </p>
    </div>

    <div class="guide-index-grid">
      {sortedGuides.map((guide) => {
        const thumbnail = getGuideThumbnail(guide);
        return (
          <a href={`/guide/${guide.slug}/`} class={`guide-card ${thumbnail ? 'has-image' : ''}`}>
            {thumbnail && (
              <div class="guide-card-image">
                <img src={thumbnail} alt={guide.title} loading="lazy" />
              </div>
            )}
            <div class="guide-card-content">
              <span class="guide-card-title">{guide.title}</span>
              <span class="guide-card-desc">{guide.seoDescription?.slice(0, 120)}...</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Base>

<style>
  .guide-index-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .guide-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .guide-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .guide-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-muted, #f5f5f5);
  }

  .guide-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .guide-card:hover .guide-card-image img {
    transform: scale(1.05);
  }

  .guide-card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .guide-card:not(.has-image) {
    background: linear-gradient(135deg, var(--color-navy, #1a1a2e) 0%, #2d2d4a 100%);
  }

  .guide-card:not(.has-image) .guide-card-content {
    padding: 2rem 1.5rem;
  }

  .guide-card:not(.has-image) .guide-card-title {
    color: #fff;
  }

  .guide-card:not(.has-image) .guide-card-desc {
    color: rgba(255, 255, 255, 0.7);
  }

  .guide-card-title {
    font-family: var(--font-display, serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text, #1a1a2e);
    line-height: 1.3;
  }

  .guide-card-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted, #6b7280);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .guide-index-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
