---
import Base from '../../layouts/Base.astro';
import StoryCard from '../../components/StoryCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getAllNeighborhoods, getStoriesByNeighborhood, slugify, SITE_URL, SITE_NAME, buildBreadcrumbSchema } from '../../lib/helpers';
import neighborhoodsData from '../../data/neighborhoods.json';

export function getStaticPaths() {
  const neighborhoods = getAllNeighborhoods();
  return neighborhoods.map((name) => ({
    params: { neighborhood: slugify(name) },
    props: { neighborhoodName: name },
  }));
}

const { neighborhoodName } = Astro.props;
const stories = getStoriesByNeighborhood(neighborhoodName);
const slug = slugify(neighborhoodName);

const hoodInfo = neighborhoodsData.neighborhoods.find((n) => n.slug === slug);
const seoTitle = hoodInfo?.seoTitle || `${neighborhoodName} Atlanta News`;
const seoDesc = hoodInfo?.seoDescription || `Latest hyperlocal news from ${neighborhoodName}, Atlanta. Coverage of development, transit, food, arts, and community stories from Inside The Perimeter.`;

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: SITE_URL },
  { name: 'Neighborhoods', url: `${SITE_URL}/neighborhoods` },
  { name: neighborhoodName, url: `${SITE_URL}/neighborhoods/${slug}` },
]);

const neighborhoodJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: seoTitle,
  description: seoDesc,
  url: `${SITE_URL}/neighborhoods/${slug}`,
  publisher: {
    '@type': 'Organization',
    name: SITE_NAME,
    url: SITE_URL,
  },
  about: {
    '@type': 'Place',
    name: neighborhoodName,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Atlanta',
      addressRegion: 'GA',
      addressCountry: 'US',
    },
  },
};
---

<Base
  title={seoTitle}
  description={seoDesc}
  jsonLd={neighborhoodJsonLd}
  breadcrumbSchema={breadcrumbSchema}
>
  <div class="page-container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Neighborhoods', href: '/neighborhoods' },
      { label: neighborhoodName },
    ]} />

    <div class="neighborhood-page-header">
      <h1 class="neighborhood-page-title">{neighborhoodName}</h1>
      <p class="neighborhood-page-subtitle">
        {stories.length} {stories.length === 1 ? 'story' : 'stories'} &middot; Inside The Perimeter, Atlanta
      </p>
    </div>

    {stories.length > 0 ? (
      <div class="story-grid story-grid-3">
        {stories.map((story) => (
          <StoryCard story={story} />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>No stories from {neighborhoodName} today. Check back tomorrow.</p>
      </div>
    )}

    {hoodInfo && (
      <section class="neighborhood-description">
        <h2 class="neighborhood-description-title">About {neighborhoodName}</h2>
        {hoodInfo.description.split('\n\n').map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </section>
    )}

    {hoodInfo?.highlights && hoodInfo.highlights.length > 0 && (
      <section class="neighborhood-highlights">
        <h2 class="neighborhood-highlights-title">Quick Facts</h2>
        <ul class="neighborhood-highlights-list">
          {hoodInfo.highlights.map((highlight) => (
            <li>{highlight}</li>
          ))}
        </ul>
      </section>
    )}

    {hoodInfo && (hoodInfo.npu || hoodInfo.zipCodes || hoodInfo.resources) && (
      <section class="neighborhood-resources">
        <h2 class="neighborhood-highlights-title">Resources</h2>
        <div class="neighborhood-resources-grid">
          {hoodInfo.npu && (
            <div class="neighborhood-resource-item">
              <span class="neighborhood-resource-label">Planning Unit</span>
              <a href={hoodInfo.npuUrl} target="_blank" rel="noopener noreferrer">NPU-{hoodInfo.npu}</a>
            </div>
          )}
          {!hoodInfo.npu && hoodInfo.name === 'Decatur' && (
            <div class="neighborhood-resource-item">
              <span class="neighborhood-resource-label">City Government</span>
              <a href="https://www.decaturga.com/" target="_blank" rel="noopener noreferrer">City of Decatur</a>
            </div>
          )}
          {hoodInfo.zipCodes && (
            <div class="neighborhood-resource-item">
              <span class="neighborhood-resource-label">Zip Codes</span>
              <span>{hoodInfo.zipCodes.join(', ')}</span>
            </div>
          )}
          {hoodInfo.resources && hoodInfo.resources.map((resource) => (
            <div class="neighborhood-resource-item">
              <a href={resource.url} target="_blank" rel="noopener noreferrer">{resource.label}</a>
            </div>
          ))}
        </div>
      </section>
    )}

    {hoodInfo?.relatedNeighborhoods && hoodInfo.relatedNeighborhoods.length > 0 && (
      <section class="related-hoods">
        <h2 class="related-hoods-title">Nearby Neighborhoods</h2>
        <div class="related-hoods-grid">
          {hoodInfo.relatedNeighborhoods.map((name) => {
            const relatedInfo = neighborhoodsData.neighborhoods.find((n) => n.name === name);
            return (
              <a href={`/neighborhoods/${slugify(name)}`} class="related-hood-card">
                <span class="related-hood-name">{name}</span>
                {relatedInfo && (
                  <span class="related-hood-blurb">{relatedInfo.highlights[0]}</span>
                )}
              </a>
            );
          })}
        </div>
      </section>
    )}

    <a href="/neighborhoods" class="back-link">&larr; All neighborhoods</a>
  </div>
</Base>
