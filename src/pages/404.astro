---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Browse Atlanta's ITP neighborhoods, read our local guides, or check today's news briefing."
>
  <div class="page-container">
    <div class="four-oh-four">
      <h1 class="four-oh-four-code">404</h1>
      <p class="four-oh-four-msg">
        That page doesn't exist. Maybe the story moved, maybe it never did.
      </p>
      <div class="four-oh-four-links">
        <a href="/">back to today's news</a>
        <a href="/neighborhoods/">browse neighborhoods</a>
        <a href="/guide/">read our guides</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .four-oh-four {
    text-align: center;
    padding: 4rem 1rem;
  }

  .four-oh-four-code {
    font-family: var(--font-display);
    font-size: clamp(5rem, 15vw, 10rem);
    line-height: 1;
    color: var(--color-line);
    letter-spacing: -0.04em;
  }

  .four-oh-four-msg {
    max-width: 28rem;
    margin: 1rem auto 2rem;
    font-size: 1.1rem;
    color: var(--color-text-soft);
    line-height: 1.6;
  }

  .four-oh-four-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }

  .four-oh-four-links a {
    display: inline-flex;
    align-items: center;
    min-height: var(--tap-target);
    padding: 0.7rem 1.2rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-soft);
  }

  .four-oh-four-links a:hover {
    color: #fff;
    background: var(--color-blue);
    border-color: var(--color-blue);
  }
</style>
