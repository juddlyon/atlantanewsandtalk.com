---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { SITE_URL, buildBreadcrumbSchema } from '../../lib/helpers';
import listsData from '../../data/lists.json';

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: SITE_URL },
  { name: 'Lists', url: `${SITE_URL}/lists` },
]);
---

<Base
  title="Atlanta Lists & Rankings"
  description="Top 10 lists and rankings for Atlanta restaurants, bars, parks, coffee shops, and more. Written by locals who actually live ITP."
  breadcrumbSchema={breadcrumbSchema}
>
  <div class="page-container">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'Lists' },
    ]} />

    <div class="neighborhood-page-header">
      <h1 class="neighborhood-page-title">Atlanta Lists</h1>
      <p class="neighborhood-page-subtitle">
        Top picks, rankings, and recommendations for the best of ITP Atlanta
      </p>
    </div>

    <div class="list-index-grid">
      {listsData.lists.map((list) => (
        <a href={`/lists/${list.slug}`} class="list-index-card">
          {list.imageUrl && (
            <img
              src={list.imageUrl}
              alt={list.imageAlt}
              class="list-index-card-image"
              loading="lazy"
              width="600"
              height="300"
            />
          )}
          <div class="list-index-card-body">
            <span class="list-index-card-count">{list.items.length} picks</span>
            <h2 class="list-index-card-title">{list.title}</h2>
            <p class="list-index-card-desc">{list.seoDescription}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
