---
import Base from '../layouts/Base.astro';
import StoryCard from '../components/StoryCard.astro';
import NeighborhoodTag from '../components/NeighborhoodTag.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getAllArchivedStories, getStoriesByNeighborhood, formatDate, SITE_URL, SITE_NAME, buildBreadcrumbSchema } from '../lib/helpers';

export function getStaticPaths() {
  // Use ALL archived stories so pages persist forever (SEO)
  const stories = getAllArchivedStories();
  return stories.map((story) => ({
    params: { slug: story.id },
    props: { story },
  }));
}

const { story } = Astro.props;

// Get related stories from the same neighborhood, excluding this one
const relatedStories = getStoriesByNeighborhood(story.neighborhood)
  .filter((s) => s.id !== story.id)
  .slice(0, 3);

const publishDate = new Date(story.publishedAt);
const dateStr = publishDate.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: story.headline,
  description: story.summary,
  image: story.imageUrl || undefined,
  datePublished: story.publishedAt,
  author: {
    '@type': 'Organization',
    name: story.source,
    url: story.sourceUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE_NAME,
    url: SITE_URL,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE_URL}/${story.id}`,
  },
  keywords: story.keywords?.join(', '),
};

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: SITE_URL },
  { name: story.neighborhood, url: `${SITE_URL}/neighborhoods/${story.neighborhood.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}` },
  { name: story.headline, url: `${SITE_URL}/${story.id}` },
]);

const bodyParagraphs = story.body.split('\n\n').filter((p: string) => p.trim());
---

<Base
  title={story.headline}
  description={story.summary}
  ogImage={story.imageUrl || undefined}
  ogType="article"
  article={{
    publishedTime: story.publishedAt,
    section: story.neighborhood,
    tags: story.keywords,
  }}
  jsonLd={articleJsonLd}
  breadcrumbSchema={breadcrumbSchema}
>
  <article class="article-page">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: story.neighborhood, href: `/neighborhoods/${story.neighborhood.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}` },
      { label: story.headline },
    ]} />

    {story.imageUrl ? (
      <img
        src={story.imageUrl}
        alt={story.imageAlt || story.headline}
        class="article-hero-image"
      />
    ) : (
      <div class="article-hero-fallback">
        <span>{story.neighborhood}</span>
      </div>
    )}

    <div class="article-meta">
      {story.neighborhoods?.map((n: string) => (
        <NeighborhoodTag name={n} size="md" />
      ))}
      <span class="article-source">
        via <a href={story.sourceUrl} target="_blank" rel="noopener noreferrer">{story.source}</a>
      </span>
      <span class="article-date">{dateStr}</span>
    </div>

    <h1 class="article-headline">{story.headline}</h1>

    <p class="article-summary">{story.summary}</p>

    <div class="article-body" set:html={story.body.split('\n\n').map((p: string) => {
      // If paragraph is already wrapped in a block element, pass through
      if (p.trim().startsWith('<blockquote') || p.trim().startsWith('<ul') || p.trim().startsWith('<ol') || p.trim().startsWith('<table') || p.trim().startsWith('<figure') || p.trim().startsWith('<img') || p.trim().startsWith('<div')) {
        return p;
      }
      return `<p>${p}</p>`;
    }).join('\n')} />

    <div class="article-footer">
      {story.sources && story.sources.length > 1 ? (
        <div class="article-sources">
          <span class="article-sources-label">Reported by {story.sources.length} sources</span>
          <div class="article-sources-list">
            {story.sources.map((s) => (
              <a href={s.url} class="article-source-link" target="_blank" rel="noopener noreferrer">
                {s.name} ›
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a href={story.sourceUrl} class="article-original-link" target="_blank" rel="noopener noreferrer">
          Read original at {story.source} ›
        </a>
      )}
    </div>

    {relatedStories.length > 0 && (
      <div class="related-section">
        <h2 class="related-title">More from {story.neighborhood}</h2>
        <div class="story-grid">
          {relatedStories.map((related) => (
            <StoryCard story={related} />
          ))}
        </div>
      </div>
    )}
  </article>
</Base>
