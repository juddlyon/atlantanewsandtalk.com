---
import Base from '../layouts/Base.astro';
import StoryCard from '../components/StoryCard.astro';
import NeighborhoodTag from '../components/NeighborhoodTag.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getAllArchivedStories, getStoriesByNeighborhood, formatDate, slugify, SITE_URL, SITE_NAME, buildBreadcrumbSchema } from '../lib/helpers';

export function getStaticPaths() {
  // Use ALL archived stories so pages persist forever (SEO)
  const stories = getAllArchivedStories();
  return stories.map((story) => ({
    params: { slug: story.id },
    props: { story },
  }));
}

const { story } = Astro.props;

// Map neighborhoods to their landing page slugs
const NEIGHBORHOOD_LANDING_PAGES: Record<string, string> = {
  'Old Fourth Ward': 'old-fourth-ward-news',
  'Grant Park': 'grant-park-atlanta-news',
  'Inman Park': 'inman-park-news',
  'East Atlanta Village': 'east-atlanta-village-news',
  'Reynoldstown': 'reynoldstown-atlanta-news',
  'Summerhill': 'summerhill-atlanta-news',
  'Kirkwood': 'kirkwood-atlanta-news',
  'Midtown': 'midtown-atlanta-news',
  'Downtown': 'downtown-atlanta-news',
  'Buckhead': 'buckhead-atlanta-news',
  'Virginia-Highland': 'virginia-highland-news',
  'Decatur': 'decatur-news',
  'West Midtown': 'west-midtown-atlanta-news',
};

// Build contextual links for this story
const contextLinks: Array<{ label: string; href: string }> = [];
const hoodSlug = NEIGHBORHOOD_LANDING_PAGES[story.neighborhood];
if (hoodSlug) {
  contextLinks.push({ label: `More ${story.neighborhood} news`, href: `/${hoodSlug}/` });
}
// Add category-relevant links based on keywords and section
const kw = (story.keywords || []).join(' ').toLowerCase();
const bodyLower = (story.body || '').toLowerCase();
if (kw.includes('restaurant') || kw.includes('food') || kw.includes('dining') || kw.includes('chef') || kw.includes('menu')) {
  contextLinks.push({ label: 'Atlanta restaurant news', href: '/atlanta-restaurants-news/' });
}
if (kw.includes('beltline') || bodyLower.includes('beltline')) {
  contextLinks.push({ label: 'BeltLine news', href: '/atlanta-beltline-news/' });
}
if (kw.includes('development') || kw.includes('housing') || kw.includes('construction') || kw.includes('redevelopment')) {
  contextLinks.push({ label: 'Atlanta development news', href: '/atlanta-development-news/' });
}
if (kw.includes('marta') || kw.includes('transit')) {
  contextLinks.push({ label: 'Atlanta transit news', href: '/atlanta-transit-news/' });
}
// Always link to today's news
contextLinks.push({ label: 'Atlanta news today', href: '/atlanta-news-today/' });

// Get related stories from the same neighborhood, excluding this one
const relatedStories = getStoriesByNeighborhood(story.neighborhood)
  .filter((s) => s.id !== story.id)
  .slice(0, 3);

const dateStr = formatDate(story.publishedAt);

const sourceUrls = story.sources?.map((s: { url: string }) => s.url) || [story.sourceUrl];

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: story.headline,
  description: story.summary,
  articleBody: story.body?.replace(/<[^>]+>/g, '').slice(0, 5000),
  articleSection: story.neighborhood,
  image: story.imageUrl ? {
    '@type': 'ImageObject',
    url: story.imageUrl.startsWith('/') ? `${SITE_URL}${story.imageUrl}` : story.imageUrl,
    caption: story.imageAlt || story.headline,
    width: 1200,
    height: 675,
  } : undefined,
  datePublished: story.publishedAt,
  dateModified: story.publishedAt,
  inLanguage: 'en-US',
  author: {
    '@type': 'Organization',
    name: story.source,
    url: story.sourceUrl,
  },
  publisher: {
    '@type': 'NewsMediaOrganization',
    '@id': `${SITE_URL}/#organization`,
    name: SITE_NAME,
    url: SITE_URL,
    logo: `${SITE_URL}/favicon.svg`,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE_URL}/${story.id}/`,
  },
  url: `${SITE_URL}/${story.id}/`,
  keywords: story.keywords?.join(', '),
  ...(sourceUrls.length > 1 ? { sameAs: sourceUrls } : { sameAs: story.sourceUrl }),
  spatialCoverage: {
    '@type': 'Place',
    name: `${story.neighborhood}, Atlanta, GA`,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Atlanta',
      addressRegion: 'GA',
      addressCountry: 'US',
    },
  },
};

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: SITE_URL },
  { name: story.neighborhood, url: `${SITE_URL}/neighborhoods/${slugify(story.neighborhood)}` },
  { name: story.headline, url: `${SITE_URL}/${story.id}` },
]);


---

<Base
  title={story.headline}
  description={story.summary}
  ogImage={story.imageUrl ? (story.imageUrl.startsWith('/') ? `${SITE_URL}${story.imageUrl}` : story.imageUrl) : undefined}
  ogType="article"
  article={{
    publishedTime: story.publishedAt,
    section: story.neighborhood,
    tags: story.keywords,
  }}
  jsonLd={articleJsonLd}
  breadcrumbSchema={breadcrumbSchema}
>
  <article class="article-page">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: story.neighborhood, href: `/neighborhoods/${slugify(story.neighborhood)}` },
      { label: story.headline },
    ]} />

    {story.imageUrl ? (
      <img
        src={story.imageUrl}
        alt={story.imageAlt || story.headline}
        class="article-hero-image"
        loading="eager"
        decoding="async"
        width="1200"
        height="675"
      />
    ) : (
      <div class="article-hero-fallback">
        <span>{story.neighborhood}</span>
      </div>
    )}

    <div class="article-meta">
      {story.neighborhoods?.map((n: string) => (
        <NeighborhoodTag name={n} size="md" />
      ))}
      <span class="article-source">
        via <a href={story.sourceUrl} target="_blank" rel="noopener noreferrer">{story.source}</a>
      </span>
      <span class="article-date">{dateStr}</span>
    </div>

    <h1 class="article-headline">{story.headline}</h1>

    <p class="article-summary">{story.summary}</p>

    <div class="article-body" set:html={story.body.split('\n\n').map((p: string) => {
      // If paragraph is already wrapped in a block element, pass through
      if (p.trim().startsWith('<blockquote') || p.trim().startsWith('<ul') || p.trim().startsWith('<ol') || p.trim().startsWith('<table') || p.trim().startsWith('<figure') || p.trim().startsWith('<img') || p.trim().startsWith('<div')) {
        return p;
      }
      return `<p>${p}</p>`;
    }).join('\n')} />

    <div class="article-footer">
      {story.sources && story.sources.length > 1 ? (
        <div class="article-sources">
          <span class="article-sources-label">Reported by {story.sources.length} sources</span>
          <div class="article-sources-list">
            {story.sources.map((s) => (
              <a href={s.url} class="article-source-link" target="_blank" rel="noopener noreferrer">
                {s.name} ›
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a href={story.sourceUrl} class="article-original-link" target="_blank" rel="noopener noreferrer">
          Read original at {story.source} ›
        </a>
      )}
    </div>

    {relatedStories.length > 0 && (
      <div class="related-section">
        <h2 class="related-title">More from {story.neighborhood}</h2>
        <div class="story-grid">
          {relatedStories.map((related) => (
            <StoryCard story={related} />
          ))}
        </div>
      </div>
    )}

    {contextLinks.length > 0 && (
      <nav class="context-links" aria-label="Related topics">
        {contextLinks.map((link) => (
          <a href={link.href} class="context-link">{link.label} ›</a>
        ))}
      </nav>
    )}
  </article>
</Base>
