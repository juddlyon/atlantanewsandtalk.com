---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE_URL, SITE_NAME, buildBreadcrumbSchema } from '../lib/helpers';

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: SITE_URL },
  { name: 'About', url: `${SITE_URL}/about` },
]);
---

<Base
  title="About | Hyperlocal ITP Atlanta News Aggregator"
  description="Atlanta News & Talk is a daily news experiment that aggregates and summarizes hyperlocal ITP Atlanta news from a dozen local sources."
  breadcrumbSchema={breadcrumbSchema}
>
  <div class="article-page">
    <Breadcrumb items={[
      { label: 'Home', href: '/' },
      { label: 'About' },
    ]} />

    <h1 class="article-headline">about atlanta news & talk</h1>

    <div class="article-body">
      <p>
        This is a sidequest. I'm a web developer who lives in Summerhill, and I got tired of checking
        a dozen different sites every morning to figure out what's going on in my own city. So I built
        something that does it for me.
      </p>

      <p>
        Every day, this site pulls from 20 local news sources, figures out what actually matters to
        people who live Inside The Perimeter, and puts it all in one place. The whole thing runs on
        <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> and
        <a href="https://www.netlify.com" target="_blank" rel="noopener">Netlify</a>. It's an experiment
        in what happens when you point modern web tools at a local news problem.
      </p>

      <blockquote>
        The SE BeltLine corridor is home base: Summerhill, Grant Park, Reynoldstown, Old Fourth Ward,
        Inman Park, East Atlanta Village, Kirkwood, Peoplestown, and the neighborhoods around them.
        That's where I live, that's what I care about most.
      </blockquote>

      <h2>What this is</h2>
      <ul>
        <li>A daily digest of hyperlocal Atlanta news, updated every morning</li>
        <li>A web dev experiment and sidequest, not a media company</li>
        <li>A way to stay plugged in without opening 20 tabs</li>
        <li>Free. No paywalls, no accounts, no tracking</li>
      </ul>

      <h2>What this isn't</h2>
      <ul>
        <li>Original reporting. Every story links back to the source.</li>
        <li>A replacement for the reporters doing the actual work. Go subscribe to <a href="https://decaturish.com" target="_blank" rel="noopener">Decaturish</a> and <a href="https://saportareport.com" target="_blank" rel="noopener">SaportaReport</a>. They need your support.</li>
        <li>Perfect. Some stories will be off, some neighborhoods get more coverage than others. I'm working on it.</li>
      </ul>

      <h2>Sources</h2>

      <table>
        <thead>
          <tr>
            <th>Source</th>
            <th>Coverage</th>
            <th>Type</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><a href="https://decaturish.com" target="_blank" rel="noopener">Decaturish</a></td><td>Decatur, East Atlanta, ITP neighborhoods</td><td>Independent</td></tr>
          <tr><td><a href="https://saportareport.com" target="_blank" rel="noopener">SaportaReport</a></td><td>Atlanta metro, politics, development</td><td>Independent</td></tr>
          <tr><td><a href="https://atlanta.urbanize.city" target="_blank" rel="noopener">Urbanize Atlanta</a></td><td>Development, construction, real estate</td><td>Independent</td></tr>
          <tr><td><a href="https://atlantaciviccircle.org" target="_blank" rel="noopener">Atlanta Civic Circle</a></td><td>City government, policy, civic issues</td><td>Nonprofit</td></tr>
          <tr><td><a href="https://roughdraftatlanta.com" target="_blank" rel="noopener">Rough Draft Atlanta</a></td><td>Arts, culture, food, community</td><td>Independent</td></tr>
          <tr><td><a href="https://www.theatlantavoice.com" target="_blank" rel="noopener">The Atlanta Voice</a></td><td>Black Atlanta, community, politics</td><td>Independent</td></tr>
          <tr><td><a href="https://atlanta.capitalbnews.org" target="_blank" rel="noopener">Capital B Atlanta</a></td><td>Black community, civil rights, local politics</td><td>Nonprofit</td></tr>
          <tr><td><a href="https://atlanta.eater.com" target="_blank" rel="noopener">Eater Atlanta</a></td><td>Restaurants, food, dining</td><td>Vox Media</td></tr>
          <tr><td><a href="https://whatnow.com/atlanta/" target="_blank" rel="noopener">What Now Atlanta</a></td><td>Restaurant and retail openings/closings</td><td>Independent</td></tr>
          <tr><td><a href="https://georgiarecorder.com" target="_blank" rel="noopener">Georgia Recorder</a></td><td>State politics, policy</td><td>Nonprofit</td></tr>
          <tr><td><a href="https://globalatlanta.com" target="_blank" rel="noopener">Global Atlanta</a></td><td>International business, trade</td><td>Independent</td></tr>
          <tr><td><a href="https://hypepotamus.com" target="_blank" rel="noopener">Hypepotamus</a></td><td>Startups, tech, innovation</td><td>Independent</td></tr>
          <tr><td><a href="https://www.atlantamagazine.com" target="_blank" rel="noopener">Atlanta Magazine</a></td><td>Culture, food, lifestyle</td><td>Magazine</td></tr>
          <tr><td><a href="https://www.11alive.com" target="_blank" rel="noopener">11Alive</a></td><td>Metro Atlanta news</td><td>TV (NBC)</td></tr>
          <tr><td><a href="https://www.wsbtv.com" target="_blank" rel="noopener">WSB-TV</a></td><td>Metro Atlanta news</td><td>TV (ABC)</td></tr>
          <tr><td><a href="https://www.fox5atlanta.com" target="_blank" rel="noopener">Fox 5 Atlanta</a></td><td>Metro Atlanta news</td><td>TV (Fox)</td></tr>
          <tr><td><a href="https://www.gpb.org" target="_blank" rel="noopener">GPB News</a></td><td>Georgia news, public interest</td><td>Public media</td></tr>
          <tr><td><a href="https://www.wabe.org" target="_blank" rel="noopener">WABE</a></td><td>Atlanta news, public interest</td><td>NPR affiliate</td></tr>
          <tr><td><a href="https://www.ajc.com" target="_blank" rel="noopener">AJC</a></td><td>Metro Atlanta, Georgia</td><td>Newspaper</td></tr>
          <tr><td><a href="https://www.axios.com/local/atlanta" target="_blank" rel="noopener">Axios Atlanta</a></td><td>Atlanta news, business, politics</td><td>Axios</td></tr>
        </tbody>
      </table>

      <h2>Get in touch</h2>
      <p>
        Got a source I should be reading? A correction? A neighborhood blog I'm missing?
        Email <a href="mailto:hey@atlantanewsandtalk.com">hey@atlantanewsandtalk.com</a>.
      </p>

      <p class="about-fine-print">
        All original reporting belongs to the respective publishers listed above. Every story links to and credits the source.
        This site is an independent project and is not affiliated with any of the sources listed.
      </p>
    </div>
  </div>
</Base>

<style>
  .about-fine-print {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
    font-size: 0.82rem;
    color: var(--color-text-soft);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }

  th, td {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--color-line);
  }

  th {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-soft);
  }

  td a {
    font-weight: 600;
  }

  blockquote {
    margin: 1.25rem 0;
    padding: 1rem 1.25rem;
    border-left: 3px solid var(--color-red);
    background: rgba(19, 39, 79, 0.04);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  ul {
    margin: 0.75rem 0;
    padding-left: 1.25rem;
  }

  li {
    margin-bottom: 0.4rem;
  }

  h2 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-ink);
  }
</style>
