---
import NeighborhoodTag from './NeighborhoodTag.astro';
import type { Story } from '../lib/helpers';

interface Props {
  story: Story;
  featured?: boolean;
  showImage?: boolean;
}

const { story, featured = false, showImage = true } = Astro.props;
const articleUrl = `/${story.id}`;
---

<article class:list={['card', { featured }]}>
  {showImage && story.imageUrl && (
    <a href={articleUrl} class="card-img-wrap">
      <img src={story.imageUrl} alt={story.imageAlt || story.headline} loading="lazy" />
    </a>
  )}
  {showImage && !story.imageUrl && (
    <a href={articleUrl} class="card-img-wrap card-img-fallback">
      <span>{story.neighborhood}</span>
    </a>
  )}
  <div class="card-body">
    <div class="card-top">
      <NeighborhoodTag name={story.neighborhood} />
      <span class="card-via">via {story.source}</span>
    </div>
    <h3 class="card-title">
      <a href={articleUrl}>{story.headline}</a>
    </h3>
    <p class="card-blurb">{story.summary}</p>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    border: 2px solid var(--color-border);
    -webkit-tap-highlight-color: transparent;
    transition: border-color 0.2s;
  }

  .card-img-wrap {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-border);
  }

  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-img-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-clay) 0%, var(--color-sage) 60%, var(--color-denim) 100%);
  }

  .card-img-fallback span {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  .card-body {
    padding: 0.875rem 1rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .card-via {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-soft);
    font-weight: 400;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0;
    font-variation-settings: "WONK" 1;
  }

  .card-title a {
    color: var(--color-ink);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }

  .card-title a:hover {
    color: var(--color-rust);
  }

  .card-blurb {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-text-soft);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured .card-title { font-size: 1.15rem; }
  .featured .card-blurb { -webkit-line-clamp: 4; }

  @media (hover: hover) {
    .card:hover {
      border-color: var(--color-rust);
    }

    .card-img-wrap img {
      transition: transform 0.35s ease;
    }

    .card:hover .card-img-wrap img {
      transform: scale(1.04);
    }
  }
</style>
