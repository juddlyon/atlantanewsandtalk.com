---
import NeighborhoodTag from './NeighborhoodTag.astro';
import type { Story } from '../lib/helpers';

interface Props {
  story: Story;
  featured?: boolean;
  showImage?: boolean;
}

const { story, featured = false, showImage = true } = Astro.props;
const articleUrl = `/${story.id}/`;
---

<article class:list={['card', { featured }]}>
  {showImage && story.imageUrl && (
    <a href={articleUrl} class="card-img-wrap">
      <img src={story.imageUrl} alt={story.imageAlt || story.headline} loading="lazy" decoding="async" width="640" height="400" />
    </a>
  )}
  {/* No fallback image block. Cards without images are text-only with the gradient stripe. */}
  <div class="card-body">
    <div class="card-top">
      <NeighborhoodTag name={story.neighborhood} />
      <span class="card-via">{story.source}</span>
    </div>
    <h3 class="card-title">
      <a href={articleUrl}>{story.headline}</a>
    </h3>
    <p class="card-blurb">{story.summary}</p>
  </div>
</article>

<style>
  .card {
    display: grid;
    overflow: hidden;
    background: rgba(255, 253, 248, 0.88);
    border-radius: calc(var(--radius) - 4px);
    border: 1px solid rgba(19, 39, 79, 0.1);
    box-shadow: var(--shadow-md);
    transform: translateY(0);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .card::before {
    content: '';
    display: block;
    height: 4px;
    background: linear-gradient(90deg, var(--color-red), var(--color-gold), var(--color-blue));
  }

  .card-img-wrap {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: rgba(19, 39, 79, 0.08);
  }

  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card-img-fallback {
    display: grid;
    place-items: center;
    background:
      linear-gradient(145deg, rgba(19, 39, 79, 0.96), rgba(19, 39, 79, 0.75)),
      linear-gradient(135deg, rgba(206, 17, 65, 0.65), rgba(141, 183, 217, 0.24));
  }

  .card-img-fallback span {
    padding: 0.4rem 0.7rem;
    border: 1px solid rgba(255, 248, 240, 0.24);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 248, 240, 0.88);
  }

  .card-body {
    display: grid;
    gap: 0.55rem;
    padding: 1rem 1rem 1.15rem;
  }

  .card-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
  }

  .card-via {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    overflow-wrap: break-word;
  }

  .card-title a {
    color: inherit;
  }

  .card-title a:hover {
    color: var(--color-red);
  }

  .card-blurb {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--color-text-soft);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  .featured .card-title {
    font-size: 1.6rem;
  }

  .featured .card-blurb {
    -webkit-line-clamp: 4;
  }

  @media (hover: hover) {
    .card:hover {
      transform: translateY(-4px);
      border-color: rgba(206, 17, 65, 0.28);
      box-shadow: 0 18px 36px rgba(16, 24, 40, 0.12);
    }

    .card:hover .card-img-wrap img {
      transform: scale(1.04);
    }
  }

  @media (min-width: 700px) {
    .card-title {
      font-size: 1.55rem;
    }
  }
</style>
