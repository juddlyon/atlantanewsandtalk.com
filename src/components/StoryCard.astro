---
import NeighborhoodTag from './NeighborhoodTag.astro';
import type { Story } from '../lib/helpers';

interface Props {
  story: Story;
  featured?: boolean;
  showImage?: boolean;
}

const { story, featured = false, showImage = true } = Astro.props;
const articleUrl = `/${story.id}`;
---

<article class:list={['story-card', { featured, 'has-image': showImage && story.imageUrl }]}>
  {showImage && story.imageUrl && (
    <a href={articleUrl} class="card-image-link">
      <div class="card-image">
        <img src={story.imageUrl} alt={story.imageAlt || story.headline} loading="lazy" />
      </div>
    </a>
  )}
  {showImage && !story.imageUrl && (
    <a href={articleUrl} class="card-image-link">
      <div class="card-image card-image-fallback">
        <span class="fallback-text">{story.neighborhood}</span>
      </div>
    </a>
  )}
  <div class="card-content">
    <div class="card-meta">
      <NeighborhoodTag name={story.neighborhood} />
      <span class="card-source">{story.source}</span>
    </div>
    <h3 class="card-headline">
      <a href={articleUrl}>{story.headline}</a>
    </h3>
    <p class="card-summary">{story.summary}</p>
  </div>
</article>

<style>
  .story-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: box-shadow 0.2s ease, transform 0.15s ease;
  }

  .story-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-1px);
  }

  .card-image-link {
    display: block;
    text-decoration: none;
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #e5e0da;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .story-card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-image-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1b2838 0%, #2d4a5e 100%);
  }

  .fallback-text {
    font-family: var(--font-display);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .card-content {
    padding: 1rem 1.1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .card-source {
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .card-headline {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .card-headline a {
    color: var(--color-text);
    text-decoration: none;
  }

  .card-headline a:hover {
    color: var(--color-accent);
  }

  .card-summary {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured .card-headline {
    font-size: 1.2rem;
  }

  .featured .card-summary {
    -webkit-line-clamp: 4;
  }
</style>
