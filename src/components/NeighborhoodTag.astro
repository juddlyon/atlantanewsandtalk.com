---
import { getNeighborhoodColor, slugify } from '../lib/helpers';

interface Props {
  name: string;
  linked?: boolean;
  size?: 'sm' | 'md';
}

const { name, linked = true, size = 'sm' } = Astro.props;
const color = getNeighborhoodColor(name);
const href = `/neighborhoods/${slugify(name)}`;
---

{linked ? (
  <a href={href} class:list={['hood-tag', `tag-${size}`]} style={`--tag-bg: ${color};`}>
    {name}
  </a>
) : (
  <span class:list={['hood-tag', `tag-${size}`]} style={`--tag-bg: ${color};`}>
    {name}
  </span>
)}

<style>
  .hood-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 10px;
    border-radius: 20px;
    background: var(--tag-bg);
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.1s, opacity 0.15s;
    text-shadow: 0 1px 2px rgba(0,0,0,0.15);
  }

  .hood-tag:hover {
    opacity: 0.85;
    color: #fff;
    transform: scale(1.05);
  }

  .hood-tag:active {
    transform: scale(0.97);
  }

  .tag-md {
    font-size: 0.68rem;
    padding: 5px 14px;
  }
</style>
