---
import { getNeighborhoodColor, slugify } from '../lib/helpers';

interface Props {
  name: string;
  linked?: boolean;
  size?: 'sm' | 'md';
}

const { name, linked = true, size = 'sm' } = Astro.props;
const color = getNeighborhoodColor(name);
const href = `/neighborhoods/${slugify(name)}`;
---

{linked ? (
  <a href={href} class:list={['hood-tag', `tag-${size}`]} style={`--tag-bg: ${color};`}>
    {name}
  </a>
) : (
  <span class:list={['hood-tag', `tag-${size}`]} style={`--tag-bg: ${color};`}>
    {name}
  </span>
)}

<style>
  .hood-tag {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--tag-bg) 14%, white);
    border: 1px solid color-mix(in srgb, var(--tag-bg) 45%, white);
    color: var(--color-ink);
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.1s, background-color 0.18s ease, border-color 0.18s ease;
  }

  .hood-tag:hover {
    color: var(--color-ink);
    transform: translateY(-1px);
    background: color-mix(in srgb, var(--tag-bg) 22%, white);
    border-color: color-mix(in srgb, var(--tag-bg) 60%, white);
  }

  .hood-tag:active {
    transform: translateY(0);
  }

  .tag-md {
    font-size: 0.7rem;
    padding: 0.52rem 0.9rem;
  }
</style>
