---
interface Props {
  href: string;
  title: string;
  description?: string;
  imageUrl?: string;
  imageAlt?: string;
  badge?: string;
  meta?: string;
  variant?: 'default' | 'tier-1' | 'tier-2' | 'tier-3';
}

const {
  href,
  title,
  description,
  imageUrl,
  imageAlt,
  badge,
  meta,
  variant = 'default'
} = Astro.props;

const hasImage = !!imageUrl;
---

<a href={href} class={`content-card ${hasImage ? 'has-image' : ''} ${variant}`}>
  {hasImage && (
    <div class="content-card-image">
      <img src={imageUrl} alt={imageAlt || title} loading="lazy" />
    </div>
  )}
  <div class="content-card-body">
    <div class="content-card-header">
      <span class="content-card-title">{title}</span>
      {badge && <span class="content-card-badge">{badge}</span>}
    </div>
    {description && (
      <span class="content-card-desc">{description}</span>
    )}
    {meta && (
      <span class="content-card-meta">{meta}</span>
    )}
  </div>
</a>

<style>
  .content-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .content-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .content-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-muted, #f5f5f5);
  }

  .content-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .content-card:hover .content-card-image img {
    transform: scale(1.05);
  }

  .content-card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .content-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .content-card-title {
    font-family: var(--font-display, serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text, #1a1a2e);
    line-height: 1.3;
  }

  .content-card-badge {
    font-family: var(--font-mono, monospace);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.5rem;
    background: var(--color-muted, #f0f0f0);
    color: var(--color-text-muted, #666);
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .content-card-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted, #6b7280);
    line-height: 1.5;
    flex: 1;
  }

  .content-card-meta {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: var(--color-text-muted, #888);
    margin-top: auto;
  }

  /* No-image fallback styles */
  .content-card:not(.has-image) .content-card-body {
    padding: 1.5rem;
  }

  /* Default gradient for cards without images */
  .content-card.default:not(.has-image) {
    background: linear-gradient(135deg, var(--color-navy, #1a1a2e) 0%, #2d2d4a 100%);
  }

  /* Tier-based gradients */
  .content-card.tier-1:not(.has-image) {
    background: linear-gradient(135deg, var(--color-navy, #1a1a2e) 0%, #2d2d4a 100%);
  }

  .content-card.tier-2:not(.has-image) {
    background: linear-gradient(135deg, #2d3748 0%, #4a5568 100%);
  }

  .content-card.tier-3:not(.has-image) {
    background: linear-gradient(135deg, #4a5568 0%, #718096 100%);
  }

  /* Text colors for no-image cards */
  .content-card:not(.has-image) .content-card-title {
    color: #fff;
  }

  .content-card:not(.has-image) .content-card-desc {
    color: rgba(255, 255, 255, 0.75);
  }

  .content-card:not(.has-image) .content-card-meta {
    color: rgba(255, 255, 255, 0.6);
  }

  .content-card:not(.has-image) .content-card-badge {
    background: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.9);
  }
</style>
