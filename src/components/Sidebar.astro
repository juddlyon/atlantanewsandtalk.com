---
import { getAllNeighborhoods, getNeighborhoodData, getAllStories, slugify, getNeighborhoodColor } from '../lib/helpers';

const neighborhoodData = getNeighborhoodData();
const allStories = getAllStories();

const topNeighborhoods = Object.entries(neighborhoodData)
  .sort((a, b) => b[1].storyCount - a[1].storyCount)
  .slice(0, 12);

const trending = allStories.slice(0, 5);
---

<aside class="sidebar">
  <div class="sidebar-box">
    <h3 class="box-title">your hood</h3>
    <div class="hood-scroll">
      {topNeighborhoods.map(([name, data]) => (
        <a
          href={`/neighborhoods/${slugify(name)}`}
          class="hood-pill"
          style={`--pill-bg: ${getNeighborhoodColor(name)};`}
        >
          {name}
          <span class="pill-n">{data.storyCount}</span>
        </a>
      ))}
    </div>
    <div class="hood-list-desktop">
      {topNeighborhoods.map(([name, data]) => (
        <a href={`/neighborhoods/${slugify(name)}`} class="hood-row">
          <span class="hood-dot" style={`background: ${getNeighborhoodColor(name)};`}></span>
          <span class="hood-name">{name}</span>
          <span class="hood-n">{data.storyCount}</span>
        </a>
      ))}
    </div>
    <a href="/neighborhoods" class="box-more">all neighborhoods →</a>
  </div>

  <div class="sidebar-box">
    <h3 class="box-title">most read</h3>
    <ol class="trending">
      {trending.map((story, i) => (
        <li class="trending-row">
          <span class="trending-i">{i + 1}</span>
          <div>
            <a href={`/${story.id}`} class="trending-hed">{story.headline}</a>
            <span class="trending-hood">{story.neighborhood}</span>
          </div>
        </li>
      ))}
    </ol>
  </div>

  <div class="sidebar-box sidebar-about">
    <h3 class="box-title">what is this?</h3>
    <p class="about-text">
      We're just some ITP folks who got tired of missing neighborhood news buried
      in 47 different websites. So we read them all and tell you what's up. Updated
      every morning with a fresh coffee.
    </p>
    <p class="about-text" style="margin-top: 0.5rem; font-size: 0.75rem; color: var(--color-text-soft);">
      Got a tip? Know a blog we should be reading?
      <a href="mailto:hey@atlantanewsandtalk.com" style="text-decoration: underline wavy; text-underline-offset: 3px;">holler at us</a>.
    </p>
  </div>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidebar-box {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
  }

  .box-title {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 900;
    color: var(--color-ink);
    margin: 0 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-ink);
    text-transform: lowercase;
    font-variation-settings: "WONK" 1;
  }

  /* Mobile: horizontal scroll pills */
  .hood-scroll {
    display: flex;
    gap: 0.4rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.25rem;
  }

  .hood-scroll::-webkit-scrollbar { display: none; }

  .hood-pill {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.7rem;
    min-height: 34px;
    background: var(--pill-bg);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    white-space: nowrap;
    border-radius: 20px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: transform 0.1s;
    text-shadow: 0 1px 2px rgba(0,0,0,0.15);
  }

  .hood-pill:hover { color: #fff; }
  .hood-pill:active { transform: scale(0.96); }

  .pill-n {
    opacity: 0.7;
    font-size: 0.55rem;
  }

  /* Desktop: vertical list */
  .hood-list-desktop {
    display: none;
    flex-direction: column;
  }

  .hood-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0;
    min-height: 36px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 500;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.15s;
  }

  .hood-row:last-child { border-bottom: none; }
  .hood-row:hover { color: var(--color-rust); }

  .hood-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hood-name { flex: 1; }

  .hood-n {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-soft);
    background: var(--color-border);
    padding: 2px 7px;
    border-radius: 10px;
  }

  .box-more {
    display: flex;
    align-items: center;
    margin-top: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-rust);
    text-decoration: none;
    min-height: 36px;
  }

  .box-more:hover { color: var(--color-rust-dark); }

  /* Trending */
  .trending {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .trending-row {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
  }

  .trending-i {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--color-border);
    line-height: 1;
    flex-shrink: 0;
    width: 1.5rem;
    font-variation-settings: "WONK" 1;
  }

  .trending-hed {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-ink);
    text-decoration: none;
    display: block;
    -webkit-tap-highlight-color: transparent;
    font-variation-settings: "WONK" 1;
  }

  .trending-hed:hover { color: var(--color-rust); }

  .trending-hood {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-soft);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    margin-top: 2px;
  }

  .about-text {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
  }

  @media (min-width: 960px) {
    .hood-scroll { display: none; }
    .hood-list-desktop { display: flex; }
    .sidebar-box { padding: 1.25rem; }
  }
</style>
