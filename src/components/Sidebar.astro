---
import { getNeighborhoodData, getAllStories, slugify, getNeighborhoodColor } from '../lib/helpers';

const neighborhoodData = getNeighborhoodData();
const allStories = getAllStories();

const topNeighborhoods = Object.entries(neighborhoodData)
  .sort((a, b) => b[1].storyCount - a[1].storyCount)
  .slice(0, 12);

const trending = allStories.slice(0, 5);
---

<aside class="sidebar">
  <div class="sidebar-box sidebar-pulse">
    <h3 class="box-title">Neighborhood pulse</h3>
    <div class="hood-scroll">
      {topNeighborhoods.map(([name, data]) => (
        <a
          href={`/neighborhoods/${slugify(name)}`}
          class="hood-pill"
          style={`--pill-bg: ${getNeighborhoodColor(name)};`}
        >
          {name}
          <span class="pill-n">{data.storyCount}</span>
        </a>
      ))}
    </div>
    <div class="hood-list-desktop">
      {topNeighborhoods.map(([name, data]) => (
        <a href={`/neighborhoods/${slugify(name)}`} class="hood-row">
          <span class="hood-dot" style={`background: ${getNeighborhoodColor(name)};`}></span>
          <span class="hood-name">{name}</span>
          <span class="hood-n">{data.storyCount}</span>
        </a>
      ))}
    </div>
    <a href="/neighborhoods" class="box-more">Browse all neighborhoods</a>
  </div>

  <div class="sidebar-box">
    <h3 class="box-title">Today’s watchlist</h3>
    <ol class="trending">
      {trending.map((story, i) => (
        <li class="trending-row">
          <span class="trending-i">{i + 1}</span>
          <div>
            <a href={`/${story.id}`} class="trending-hed">{story.headline}</a>
            <span class="trending-hood">{story.neighborhood}</span>
          </div>
        </li>
      ))}
    </ol>
  </div>

  <div class="sidebar-box sidebar-spotlight">
    <h3 class="box-title">Spotlight</h3>
    <div class="spotlight-items">
      <a href="/guide/fifa-world-cup-atlanta-2026" class="spotlight-card">
        <span class="spotlight-label">Guide</span>
        <span class="spotlight-hed">FIFA World Cup Atlanta 2026</span>
        <span class="spotlight-sub">Match schedule, MARTA plans, watch parties, neighborhood impact</span>
      </a>
      <a href="/the-row-900-peoplestown" class="spotlight-card">
        <span class="spotlight-label">Peoplestown</span>
        <span class="spotlight-hed">The Row 900 Breaks Ground</span>
        <span class="spotlight-sub">16-home development on Hank Aaron Drive</span>
      </a>
    </div>
  </div>

  <div class="sidebar-box">
    <h3 class="box-title">How it works</h3>
    <p class="about-text">
      The site tracks local outlets, neighborhood publications, and city coverage, then distills the strongest stories into a daily Atlanta briefing.
    </p>
    <p class="about-text sidebar-note">
      Have a source we should follow or a correction to send?
      <a href="/contact">Send us a tip</a>.
    </p>
  </div>
</aside>

<style>
  .sidebar {
    display: grid;
    gap: 1.25rem;
    min-width: 0;
    max-width: 100%;
  }

  .sidebar-box {
    padding: 1.05rem;
    border: 1px solid rgba(19, 39, 79, 0.1);
    border-radius: calc(var(--radius) - 4px);
    background: rgba(255, 253, 248, 0.82);
    box-shadow: var(--shadow-md);
    min-width: 0;
    overflow: hidden;
  }

  .sidebar-pulse {
    background:
      linear-gradient(145deg, rgba(19, 39, 79, 0.98), rgba(19, 39, 79, 0.88)),
      linear-gradient(135deg, rgba(206, 17, 65, 0.18), transparent 55%);
  }

  .box-title {
    margin: 0 0 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }

  .sidebar-pulse .box-title {
    color: rgba(255, 247, 238, 0.62);
  }

  .hood-scroll {
    display: flex;
    gap: 0.45rem;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 0.25rem;
  }

  .hood-scroll::-webkit-scrollbar {
    display: none;
  }

  .hood-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 2.4rem;
    padding: 0.5rem 0.8rem;
    border: 1px solid rgba(255, 248, 240, 0.16);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 0 0 999px rgba(255, 255, 255, 0.06);
    color: #fff7ee;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    white-space: nowrap;
  }

  .hood-pill:hover {
    color: #fff;
    transform: translateY(-1px);
  }

  .pill-n {
    opacity: 0.68;
    font-size: 0.58rem;
  }

  .hood-list-desktop {
    display: none;
    gap: 0.2rem;
    margin-top: 0.5rem;
  }

  .hood-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.35rem;
    padding: 0.45rem 0;
    color: #fff7ee;
    font-size: 0.84rem;
    font-weight: 500;
    border-bottom: 1px solid rgba(255, 248, 240, 0.1);
  }

  .hood-row:last-child {
    border-bottom: none;
  }

  .hood-row:hover {
    color: #fff;
  }

  .hood-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hood-name {
    flex: 1;
  }

  .hood-n {
    padding: 2px 7px;
    border-radius: 10px;
    background: rgba(255, 248, 240, 0.12);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(255, 247, 238, 0.8);
  }

  .box-more {
    display: inline-flex;
    align-items: center;
    margin-top: 0.8rem;
    min-height: 2.2rem;
    color: rgba(255, 247, 238, 0.92);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .box-more:hover {
    color: #fff;
  }

  .sidebar-spotlight {
    background:
      linear-gradient(145deg, rgba(206, 17, 65, 0.06), transparent 60%),
      rgba(255, 253, 248, 0.92);
    border-color: rgba(206, 17, 65, 0.18);
  }

  .spotlight-items {
    display: grid;
    gap: 0.7rem;
  }

  .spotlight-card {
    display: block;
    padding: 0.7rem 0.8rem;
    border-radius: 6px;
    background: rgba(19, 39, 79, 0.04);
    border: 1px solid rgba(19, 39, 79, 0.08);
    transition: border-color 0.15s, background 0.15s;
  }

  .spotlight-card:hover {
    border-color: var(--color-red);
    background: rgba(206, 17, 65, 0.04);
  }

  .spotlight-label {
    display: inline-block;
    margin-bottom: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .spotlight-hed {
    display: block;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .spotlight-sub {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.78rem;
    line-height: 1.4;
    color: var(--color-text-soft);
  }

  .trending {
    display: grid;
    gap: 0.8rem;
    list-style: none;
  }

  .trending-row {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
  }

  .trending-i {
    display: grid;
    place-items: center;
    width: 2rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: rgba(19, 39, 79, 0.08);
    color: var(--color-blue);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .trending-hed {
    display: block;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1;
    letter-spacing: -0.03em;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .trending-hed:hover {
    color: var(--color-red);
  }

  .trending-hood {
    display: block;
    margin-top: 0.25rem;
    color: var(--color-text-soft);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .about-text {
    font-size: 0.93rem;
    line-height: 1.7;
    color: var(--color-text-soft);
    overflow-wrap: break-word;
  }

  .sidebar-note {
    margin-top: 0.7rem;
    font-size: 0.84rem;
  }

  .sidebar-note a {
    color: var(--color-red);
  }

  @media (min-width: 980px) {
    .sidebar {
      position: sticky;
      top: 8rem;
    }

    .hood-scroll {
      display: none;
    }

    .hood-list-desktop {
      display: grid;
    }
  }
</style>
