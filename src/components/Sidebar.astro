---
import NeighborhoodTag from './NeighborhoodTag.astro';
import { getAllNeighborhoods, getNeighborhoodData, getAllStories, slugify } from '../lib/helpers';

const neighborhoods = getAllNeighborhoods();
const neighborhoodData = getNeighborhoodData();
const allStories = getAllStories();

const topNeighborhoods = Object.entries(neighborhoodData)
  .sort((a, b) => b[1].storyCount - a[1].storyCount)
  .slice(0, 12);

const trending = allStories.slice(0, 5);
---

<aside class="sidebar">
  <!-- Neighborhoods — horizontal scroll on mobile, vertical list on desktop -->
  <div class="sidebar-section sidebar-neighborhoods">
    <h3 class="sidebar-title">Neighborhoods</h3>
    <div class="neighborhood-scroll">
      {topNeighborhoods.map(([name, data]) => (
        <a href={`/neighborhoods/${slugify(name)}`} class="neighborhood-chip">
          {name}
          <span class="chip-count">{data.storyCount}</span>
        </a>
      ))}
    </div>
    <div class="neighborhood-list-desktop">
      {topNeighborhoods.map(([name, data]) => (
        <a href={`/neighborhoods/${slugify(name)}`} class="neighborhood-link">
          <span class="neighborhood-name">{name}</span>
          <span class="neighborhood-count">{data.storyCount}</span>
        </a>
      ))}
    </div>
    <a href="/neighborhoods" class="sidebar-see-all">All neighborhoods →</a>
  </div>

  <!-- Trending -->
  <div class="sidebar-section">
    <h3 class="sidebar-title">Trending</h3>
    <ol class="trending-list">
      {trending.map((story, i) => (
        <li class="trending-item">
          <span class="trending-number">{String(i + 1).padStart(2, '0')}</span>
          <div class="trending-content">
            <a href={`/${story.id}`} class="trending-headline">{story.headline}</a>
            <span class="trending-neighborhood">{story.neighborhood}</span>
          </div>
        </li>
      ))}
    </ol>
  </div>

  <!-- About -->
  <div class="sidebar-section sidebar-about">
    <h3 class="sidebar-title">About</h3>
    <p class="sidebar-text">
      Your daily dose of what's happening Inside The Perimeter. We read the local
      blogs, papers, and newsrooms so you don't have to. Neighborhood-level coverage
      from the people who actually live here.
    </p>
  </div>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidebar-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1rem;
  }

  .sidebar-title {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-navy);
    margin: 0 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-accent);
  }

  /* Mobile: horizontal scrollable chips */
  .neighborhood-scroll {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.25rem;
  }

  .neighborhood-scroll::-webkit-scrollbar { display: none; }

  .neighborhood-chip {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.75rem;
    min-height: 36px;
    background: var(--color-tag);
    color: var(--color-tag-text);
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
    border-radius: 20px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .neighborhood-chip:hover {
    background: var(--color-border);
    color: var(--color-text);
  }

  .chip-count {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    opacity: 0.7;
  }

  /* Desktop: vertical list (hidden on mobile) */
  .neighborhood-list-desktop {
    display: none;
    flex-direction: column;
    gap: 1px;
  }

  .neighborhood-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    min-height: 36px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.85rem;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.15s;
  }

  .neighborhood-link:last-child { border-bottom: none; }
  .neighborhood-link:hover { color: var(--color-accent); }

  .neighborhood-count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background: var(--color-tag);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .sidebar-see-all {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    min-height: 36px;
    display: flex;
    align-items: center;
  }

  .sidebar-see-all:hover { color: var(--color-accent-hover); }

  /* Trending */
  .trending-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .trending-item {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
  }

  .trending-number {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-border);
    line-height: 1.2;
    flex-shrink: 0;
  }

  .trending-content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .trending-headline {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }

  .trending-headline:hover { color: var(--color-accent); }

  .trending-neighborhood {
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }

  .sidebar-text {
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Desktop: switch to vertical list */
  @media (min-width: 960px) {
    .neighborhood-scroll {
      display: none;
    }

    .neighborhood-list-desktop {
      display: flex;
    }

    .sidebar-section {
      padding: 1.25rem;
    }
  }
</style>
