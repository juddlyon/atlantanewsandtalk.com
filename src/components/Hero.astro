---
import NeighborhoodTag from './NeighborhoodTag.astro';
import type { Story } from '../lib/helpers';

interface Props {
  story: Story;
}

const { story } = Astro.props;
const articleUrl = `/${story.id}/`;
const bgImage = story.imageUrl || '';
---

<section class="hero">
  <a href={articleUrl} class="hero-link">
    <div class="hero-shell">
      <div class="hero-copy">
        <div class="hero-eyebrow">
          <span class="hero-flag">Lead story</span>
          <span class="hero-source">{story.source}</span>
        </div>
        <h1 class="hero-headline">{story.headline}</h1>
        <p class="hero-summary">{story.summary}</p>
        <div class="hero-bottom">
          <NeighborhoodTag name={story.neighborhood} linked={false} size="md" />
          <span class="hero-cta">Read full brief</span>
        </div>
      </div>
      <div class="hero-image">
        {bgImage && <img src={bgImage} alt={story.imageAlt || story.headline} class="hero-img" loading="eager" decoding="async" fetchpriority="high" width="640" height="400" />}
        <div class="hero-image-badge" aria-hidden="true">ATL</div>
      </div>
    </div>
  </a>
</section>

<style>
  .hero {
    margin-bottom: 1.6rem;
  }

  .hero-link {
    display: block;
    color: inherit;
  }

  .hero-shell {
    display: grid;
    overflow: hidden;
    border: 1px solid rgba(19, 39, 79, 0.08);
    border-radius: calc(var(--radius) + 10px);
    background: var(--color-panel-strong);
    box-shadow: var(--shadow-lg);
  }

  .hero-copy {
    display: grid;
    align-content: start;
    gap: 1rem;
    padding: 1.25rem;
    background:
      linear-gradient(145deg, rgba(19, 39, 79, 0.98), rgba(19, 39, 79, 0.86)),
      linear-gradient(135deg, rgba(206, 17, 65, 0.2), transparent 52%);
  }

  .hero-eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .hero-flag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    background: var(--color-red);
    color: #fff;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
  }

  .hero-source {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 247, 238, 0.88);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 7vw, 4.3rem);
    line-height: 0.94;
    color: #fff;
    letter-spacing: -0.05em;
  }

  .hero-summary {
    max-width: 38rem;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 247, 238, 0.92);
  }

  .hero-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .hero-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255, 247, 238, 0.9);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-image {
    position: relative;
    min-height: 300px;
    overflow: hidden;
    background-color: var(--color-blue);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }

  .hero-image::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 45%;
    background: linear-gradient(180deg, transparent, rgba(15, 26, 46, 0.28));
  }

  .hero-image-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: grid;
    place-items: center;
    width: 3.25rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: rgba(255, 250, 242, 0.92);
    color: var(--color-blue);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    z-index: 1;
  }

  @media (min-width: 640px) {
    .hero-copy {
      padding: 1.6rem;
    }

    .hero-image {
      min-height: 360px;
    }
  }

  @media (min-width: 980px) {
    .hero-shell {
      grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    }

    .hero-copy {
      padding: 2rem;
    }

    .hero-image {
      min-height: 100%;
    }
  }
</style>
