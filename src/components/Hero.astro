---
import NeighborhoodTag from './NeighborhoodTag.astro';
import type { Story } from '../lib/helpers';

interface Props {
  story: Story;
}

const { story } = Astro.props;
const articleUrl = `/${story.id}`;
const bgImage = story.imageUrl || '';
---

<section class="hero">
  <a href={articleUrl} class="hero-link">
    <div class="hero-image" style={bgImage ? `background-image: url('${bgImage}')` : ''}>
      <div class="hero-overlay">
        <div class="hero-content">
          <div class="hero-label">Top Story</div>
          <div class="hero-tags">
            <NeighborhoodTag name={story.neighborhood} linked={false} size="md" />
            <span class="hero-source">{story.source}</span>
          </div>
          <h1 class="hero-headline">{story.headline}</h1>
          <p class="hero-summary">{story.summary}</p>
          <span class="hero-cta">Read full story →</span>
        </div>
      </div>
    </div>
  </a>
</section>

<style>
  .hero {
    margin-bottom: 1.5rem;
    /* bleed to edges on mobile */
    margin-left: -0.875rem;
    margin-right: -0.875rem;
  }

  .hero-link {
    text-decoration: none;
    color: inherit;
    display: block;
    -webkit-tap-highlight-color: transparent;
  }

  .hero-image {
    position: relative;
    min-height: 320px;
    background-size: cover;
    background-position: center;
    background-color: #1b2838;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 15, 25, 0.95) 0%,
      rgba(10, 15, 25, 0.7) 45%,
      rgba(10, 15, 25, 0.2) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 1.25rem 1rem;
  }

  .hero-content {
    width: 100%;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 0.6rem;
    font-weight: 600;
  }

  .hero-tags {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }

  .hero-source {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
    margin: 0 0 0.6rem;
  }

  .hero-summary {
    font-size: 0.9rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  /* Tablet+ */
  @media (min-width: 640px) {
    .hero {
      margin-left: 0;
      margin-right: 0;
      margin-bottom: 2rem;
    }

    .hero-image {
      min-height: 400px;
      border-radius: 8px;
    }

    .hero-overlay {
      padding: 2rem;
    }

    .hero-headline {
      font-size: 1.85rem;
    }

    .hero-summary {
      font-size: 1rem;
      -webkit-line-clamp: 4;
      max-width: 600px;
    }
  }

  /* Desktop */
  @media (min-width: 960px) {
    .hero-image {
      min-height: 440px;
    }

    .hero-overlay {
      padding: 2.5rem;
    }

    .hero-content {
      max-width: 680px;
    }

    .hero-headline {
      font-size: 2.1rem;
    }
  }
</style>
