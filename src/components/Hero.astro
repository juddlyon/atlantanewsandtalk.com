---
import NeighborhoodTag from './NeighborhoodTag.astro';
import type { Story } from '../lib/helpers';

interface Props {
  story: Story;
}

const { story } = Astro.props;
const articleUrl = `/${story.id}`;
const bgImage = story.imageUrl || '';
---

<section class="hero">
  <a href={articleUrl} class="hero-link">
    <div class="hero-image" style={bgImage ? `background-image: url('${bgImage}')` : ''}>
      <div class="hero-overlay">
        <div class="hero-content">
          <div class="hero-eyebrow">
            <span class="hero-flag">top story</span>
            <span class="hero-source">via {story.source}</span>
          </div>
          <h1 class="hero-headline">{story.headline}</h1>
          <div class="hero-bottom">
            <NeighborhoodTag name={story.neighborhood} linked={false} size="md" />
            <span class="hero-cta">keep reading →</span>
          </div>
        </div>
      </div>
    </div>
  </a>
</section>

<style>
  .hero {
    margin-bottom: 1.5rem;
    margin-left: -1rem;
    margin-right: -1rem;
  }

  .hero-link {
    text-decoration: none;
    color: inherit;
    display: block;
    -webkit-tap-highlight-color: transparent;
  }

  .hero-image {
    position: relative;
    min-height: 340px;
    background-size: cover;
    background-position: center;
    background-color: var(--color-ink);
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 12, 8, 0.95) 0%,
      rgba(10, 12, 8, 0.5) 50%,
      rgba(10, 12, 8, 0.15) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 1.25rem 1rem;
  }

  .hero-content {
    width: 100%;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .hero-flag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--color-rust);
    color: #fff;
    padding: 3px 10px;
    border-radius: 3px;
  }

  .hero-source {
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 500;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 900;
    line-height: 1.15;
    color: #fff;
    margin: 0 0 0.85rem;
    font-variation-settings: "WONK" 1;
  }

  .hero-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .hero-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-peach);
    letter-spacing: 0.02em;
  }

  @media (min-width: 640px) {
    .hero {
      margin-left: 0;
      margin-right: 0;
      margin-bottom: 2rem;
    }

    .hero-image {
      min-height: 420px;
      border-radius: var(--radius);
    }

    .hero-overlay { padding: 2rem; }
    .hero-headline { font-size: 2rem; }
  }

  @media (min-width: 960px) {
    .hero-image { min-height: 460px; }
    .hero-overlay { padding: 2.5rem; }
    .hero-content { max-width: 640px; }
    .hero-headline { font-size: 2.4rem; }
  }
</style>
