---
import SEO from '../components/SEO.astro';
import { formatDate, getDigest, SITE_NAME } from '../lib/helpers';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  article?: {
    publishedTime?: string;
    section?: string;
    tags?: string[];
  };
  jsonLd?: object;
}

const {
  title,
  description,
  ogImage,
  ogType,
  article,
  jsonLd,
} = Astro.props;

const digest = getDigest();
const dateDisplay = formatDate(digest.date);

const navItems = [
  { label: 'hoods', href: '/neighborhoods' },
  { label: 'development', href: '/#development-housing' },
  { label: 'transit', href: '/#transit-infrastructure' },
  { label: 'food', href: '/#food-drink' },
  { label: 'culture', href: '/#arts-culture' },
  { label: 'politics', href: '/#politics-policy' },
  { label: 'safety', href: '/#public-safety' },
  { label: 'community', href: '/#community' },
  { label: 'biz', href: '/#business' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      article={article}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <header class="site-header">
      <div class="header-top">
        <div class="site-brand">
          <a href="/" class="site-name">atlanta news <span class="amp">&</span> talk</a>
          <div class="site-tagline">itp neighborhood news, daily</div>
        </div>
        <div class="header-date">{dateDisplay}</div>
      </div>
      <nav class="header-nav">
        <div class="nav-inner">
          <a href="/" class="nav-link">home</a>
          {navItems.map((item) => (
            <a href={item.href} class="nav-link">{item.label}</a>
          ))}
        </div>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href="/" class="site-name">atlanta news <span class="amp">&</span> talk</a>
          <p class="footer-description">
            We read all the local Atlanta blogs and newsrooms every morning
            so you can find out what's happening in your neighborhood without
            opening 15 tabs. You're welcome.
          </p>
        </div>
        <div class="footer-sources">
          <h4>we read these so you don't have to</h4>
          <div class="footer-source-list">
            Decaturish · SaportaReport · Urbanize Atlanta ·
            Atlanta Civic Circle · Axios Atlanta · What Now Atlanta ·
            Patch · Rough Draft Atlanta
          </div>
        </div>
      </div>
      <div class="footer-links">
        <div class="footer-links-inner">
          <div class="footer-link-group">
            <h4>topics</h4>
            <a href="/atlanta-news-today">atlanta news today</a>
            <a href="/atlanta-development-news">development news</a>
            <a href="/atlanta-restaurants-news">restaurant news</a>
            <a href="/atlanta-transit-news">transit + marta</a>
            <a href="/things-to-do-in-atlanta">things to do</a>
            <a href="/atlanta-events-this-weekend">weekend events</a>
            <a href="/atlanta-beltline-news">beltline news</a>
          </div>
          <div class="footer-link-group">
            <h4>se beltline</h4>
            <a href="/old-fourth-ward-news">old fourth ward</a>
            <a href="/grant-park-atlanta-news">grant park</a>
            <a href="/inman-park-news">inman park</a>
            <a href="/east-atlanta-village-news">east atlanta village</a>
            <a href="/reynoldstown-atlanta-news">reynoldstown</a>
            <a href="/summerhill-atlanta-news">summerhill</a>
            <a href="/kirkwood-atlanta-news">kirkwood</a>
          </div>
          <div class="footer-link-group">
            <h4>more hoods</h4>
            <a href="/midtown-atlanta-news">midtown</a>
            <a href="/downtown-atlanta-news">downtown</a>
            <a href="/buckhead-atlanta-news">buckhead</a>
            <a href="/virginia-highland-news">virginia-highland</a>
            <a href="/decatur-news">decatur</a>
            <a href="/west-midtown-atlanta-news">west midtown</a>
            <a href="/neighborhoods">all neighborhoods →</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        © {new Date().getFullYear()} atlanta news & talk · all original reporting
        belongs to the respective publishers · we just connect the dots
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
