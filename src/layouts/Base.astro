---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Atlanta News & Talk',
  description = 'Daily hyperlocal news digest from Inside The Perimeter',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href="/" class="site-name">Atlanta News <span>&</span> Talk</a>
        <div class="site-tagline">Hyperlocal ITP · Daily Digest</div>
      </div>
    </header>

    <main class="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <p>Aggregated & summarized daily from local Atlanta sources.</p>
        <p class="source-list">
          Sources: Decaturish · SaportaReport · Urbanize Atlanta · Atlanta Civic Circle · Axios Atlanta · What Now Atlanta · Atlanta INtown Paper · Rough Draft Atlanta
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
