{
  "name": "atlantanewsandtalk.com",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fetch": "node scripts/fetch-articles.mjs",
    "summarize": "node scripts/summarize.mjs",
    "validate": "node scripts/validate-digest.mjs",
    "validate:build": "node scripts/validate-build.mjs",
    "update": "node scripts/fetch-articles.mjs && node scripts/summarize.mjs && node scripts/validate-digest.mjs",
    "publish": "npm run build && git add src/data/digest-*.json && git commit -m \"update digest $(date +%Y-%m-%d)\" && git push && npm run deploy && npm run test:deploy",
    "rollback": "node scripts/rollback.mjs",
    "images": "node scripts/download-images.mjs && node scripts/download-content-images.mjs",
    "deploy": "netlify deploy --prod --dir=dist",
    "test:deploy": "node scripts/smoke-test.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@astrojs/netlify": "^7.0.2",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@netlify/blobs": "^10.7.2",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.4",
    "cheerio": "^1.2.0",
    "crawlee": "^3.16.0",
    "marked": "^17.0.4",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
